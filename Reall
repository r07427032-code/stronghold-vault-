5<!DOCTYPE html>  
<html lang="en">  
<head>  
    <meta charset="UTF-8">  
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  
    <title>STRONGHOLD // NOVA SCOTIA NODE</title>  
    <script src="https://cdn.tailwindcss.com"></script>  
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>  
    <style>  
        :root {  
            --bg-core: #020204;  
            --bg-elevated: #08080a;  
            --signal-cyan: 34, 211, 238;  
            --signal-red: 239, 68, 68;  
            --signal-amber: 245, 158, 11;  
            --text-primary: rgba(255, 255, 255, 0.95);  
            --text-muted: rgba(255, 255, 255, 0.35);  
            --text-dim: rgba(255, 255, 255, 0.1);  
            --border-subtle: rgba(255, 255, 255, 0.04);  
        }  
  
        body {  
            background-color: var(--bg-core);  
            color: var(--text-primary);  
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;  
            overflow-x: hidden;  
            margin: 0;  
            cursor: crosshair;  
        }  
  
        .vault-scanlines {  
            position: fixed;  
            inset: 0;  
            background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.1) 50%);  
            background-size: 100% 4px;  
            pointer-events: none;  
            z-index: 100;  
            opacity: 0.15;  
        }  
  
        .noise-overlay {  
            position: fixed;  
            inset: 0;  
            pointer-events: none;  
            z-index: 99;  
            opacity: 0.02;  
            background-image: url("https://www.transparenttextures.com/patterns/stardust.png");  
        }  
  
        .vignette {  
            position: fixed;  
            inset: 0;  
            pointer-events: none;  
            z-index: 101;  
            box-shadow: inset 0 0 150px rgba(0,0,0,0.9);  
        }  
  
        .chart-container {  
            position: relative;  
            width: 100%;  
            height: 200px;  
        }  
  
        @keyframes signal-glitch {  
            0% { transform: translate(0); }  
            20% { transform: translate(-2px, 2px); }  
            40% { transform: translate(-2px, -2px); }  
            60% { transform: translate(2px, 2px); }  
            80% { transform: translate(2px, -2px); }  
            100% { transform: translate(0); }  
        }  
  
        .glitch-active {  
            animation: signal-glitch 0.15s cubic-bezier(.25,.46,.45,.94) both infinite;  
        }  
  
        .awakening-image {  
            transition: transform 3s cubic-bezier(0.16, 1, 0.3, 1), filter 3s cubic-bezier(0.16, 1, 0.3, 1), opacity 3s ease;  
            filter: grayscale(100%) brightness(20%) contrast(1.2);  
        }  
  
        .awakening-image.active {  
            filter: grayscale(0%) brightness(100%) contrast(1);  
            transform: scale(1.05);  
        }  
  
        .archive-transition {  
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);  
        }  
  
        .terminal-input {  
            background: transparent;  
            border: none;  
            color: var(--signal-cyan);  
            outline: none;  
            width: 100%;  
            font-family: inherit;  
        }  
  
        ::-webkit-scrollbar { width: 4px; }  
        ::-webkit-scrollbar-track { background: var(--bg-core); }  
        ::-webkit-scrollbar-thumb { background: var(--text-dim); border-radius: 10px; }  
    </style>  
</head>  
<body>  
    <div class="vault-scanlines"></div>  
    <div class="noise-overlay"></div>  
    <div class="vignette"></div>  
  
    <div class="relative z-[10] min-h-screen flex flex-col p-6 md:p-12 lg:p-16">  
          
        <!-- HEADER -->  
        <header class="flex justify-between items-start mb-12 opacity-50">  
            <div class="space-y-1">  
                <p class="text-[9px] uppercase tracking-[0.8em] font-bold text-cyan-400">Node_Authorization: Nova_Scotia</p>  
                <h2 class="text-[10px] font-mono tracking-widest">STRONGHOLD_VAULT // ROOT_ARCHIVE</h2>  
            </div>  
            <div class="text-right font-mono text-[9px] space-y-1 uppercase tracking-widest">  
                <p id="timestamp">SYNCING...</p>  
                <p id="signal-status">Status: Entropy_Stable</p>  
            </div>  
        </header>  
  
        <!-- MAIN VIEWPORT -->  
        <main class="flex-grow grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">  
              
            <!-- LEFT: NARRATIVE -->  
            <section class="lg:col-span-5 space-y-12">  
                <div id="content-block" class="archive-transition space-y-8">  
                    <div class="space-y-4">  
                        <div class="flex items-center gap-4 text-cyan-500/50">  
                            <span class="text-xs">⎊</span>  
                            <p class="text-[9px] font-black uppercase tracking-[0.6em]" id="archive-label">Protocol_Initiated: Root_Chronos</p>  
                        </div>  
                        <h1 class="text-6xl md:text-8xl font-black italic tracking-tighter uppercase leading-[0.85] text-white" id="archive-title">  
                            Root<br>Chronos  
                        </h1>  
                    </div>  
  
                    <div class="border-l border-white/10 pl-8 space-y-6 max-w-md">  
                        <div id="desc-container" class="relative min-h-[60px]">  
                            <p class="text-[11px] text-white/40 italic leading-relaxed uppercase tracking-[0.2em]" id="archive-description">  
                                The origin is not a start point, but the first solved variable. Backwards logic confirms the collapse was intentional.  
                            </p>  
                        </div>  
                          
                        <div class="flex flex-wrap gap-4 pt-4">  
                            <button onclick="aiDecipherDescription()" class="text-[9px] text-cyan-400/60 hover:text-cyan-400 flex items-center gap-2 uppercase tracking-widest transition-colors">  
                                <span>◈</span> Decipher_Lore  
                            </button>  
                            <button onclick="aiVocalize()" class="text-[9px] text-white/20 hover:text-white flex items-center gap-2 uppercase tracking-widest transition-colors">  
                                <span>▣</span> Vocalize_Node  
                            </button>  
                        </div>  
  
                        <div class="flex items-center gap-4 text-[9px] text-white/20 font-bold">  
                            <span>⌬</span> <span id="archive-metadata">ENTROPY_STABLE // ARCHIVE_01</span>  
                        </div>  
                    </div>  
                </div>  
  
                <nav class="flex gap-4">  
                    <button onclick="switchArchive('AX01')" class="px-6 py-3 border border-white/10 hover:border-cyan-500/50 hover:text-cyan-400 transition-all text-[10px] tracking-[0.4em] uppercase font-bold bg-white/5 rounded-sm">AX-01</button>  
                    <button onclick="switchArchive('AX02')" class="px-6 py-3 border border-white/10 hover:border-cyan-500/50 hover:text-cyan-400 transition-all text-[10px] tracking-[0.4em] uppercase font-bold bg-white/5 rounded-sm">AX-02</button>  
                    <button onclick="switchArchive('AX03')" class="px-6 py-3 border border-white/10 hover:border-red-500/50 hover:text-red-400 transition-all text-[10px] tracking-[0.4em] uppercase font-bold bg-white/5 rounded-sm">AX-03</button>  
                </nav>  
            </section>  
  
            <!-- RIGHT: DATA VISUALS -->  
            <section class="lg:col-span-7 space-y-12">  
                <div class="relative group">  
                    <div id="glitch-wrapper" class="relative aspect-video rounded-[30px] overflow-hidden border border-white/5 bg-black shadow-2xl transition-all duration-700">  
                        <img id="main-visual" src="https://images.unsplash.com/photo-1614728894747-a83421e2b9c9?w=1200&q=80" class="awakening-image w-full h-full object-cover">  
                        <div id="synth-loader" class="hidden absolute inset-0 bg-black/80 backdrop-blur-md flex flex-col items-center justify-center space-y-4">  
                            <div class="w-8 h-8 border-2 border-cyan-500/20 border-t-cyan-500 rounded-full animate-spin"></div>  
                            <p class="text-[9px] tracking-[0.5em] text-cyan-400 uppercase">Neural_Synthesis_Active</p>  
                        </div>  
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>  
                        <div class="absolute bottom-8 right-8">  
                            <button onclick="aiSynthesizeVisual()" class="bg-black/40 hover:bg-cyan-500/20 backdrop-blur-md border border-white/10 px-4 py-2 rounded-full text-[8px] font-bold tracking-widest text-white uppercase transition-all">  
                                Synthesize_Visual  
                            </button>  
                        </div>  
                    </div>  
                </div>  
  
                <div class="grid md:grid-cols-2 gap-8">  
                    <div class="p-6 border border-white/5 bg-white/[0.02] rounded-2xl space-y-4">  
                        <p class="text-[8px] uppercase tracking-[0.5em] text-white/30">System_Stability_Matrix</p>  
                        <div class="chart-container">  
                            <canvas id="stabilityChart"></canvas>  
                        </div>  
                    </div>  
                    <div class="p-6 border border-white/5 bg-white/[0.02] rounded-2xl space-y-4 flex flex-col">  
                        <p class="text-[8px] uppercase tracking-[0.5em] text-white/30">Temporal_Drift_Log</p>  
                        <div id="terminal-display" class="flex-grow overflow-y-auto text-[10px] space-y-2 font-mono text-white/40 leading-relaxed pr-2 h-32">  
                            <p class="text-cyan-400/80">>> SECURE CONNECTION ESTABLISHED.</p>  
                        </div>  
                        <div class="flex gap-2 items-center border-t border-white/5 pt-4">  
                            <span class="text-cyan-500 font-bold text-xs">></span>  
                            <input type="text" id="terminal-input" placeholder="QUERY VAULT..." class="terminal-input text-[10px] tracking-widest uppercase" onkeypress="handleTerminalEntry(event)">  
                        </div>  
                    </div>  
                </div>  
            </section>  
        </main>  
  
        <!-- FOOTER -->  
        <footer class="mt-12 flex justify-between items-center border-t border-white/5 pt-8 opacity-40">  
            <div class="flex items-center gap-6">  
                <p class="text-[8px] uppercase tracking-[0.5em]">Nova_Scotia_Vault_Index</p>  
                <div id="audio-status" class="text-[8px] font-bold uppercase tracking-widest text-cyan-400 hidden lg:block">System_Dormant</div>  
            </div>  
            <button onclick="toggleAudio()" id="audio-btn" class="p-4 rounded-xl border border-white/5 hover:border-cyan-500/30 transition-all">  
                <span id="audio-icon" class="text-xs">⧒</span>  
            </button>  
        </footer>  
    </div>  
  
    <script>  
        const state = {  
            currentArchive: 'AX01',  
            isMuted: true,  
            archives: {  
                AX01: {  
                    title: "Root<br>Chronos",  
                    label: "Protocol_Initiated: Root_Chronos",  
                    desc: "The origin is not a start point, but the first solved variable. Backwards logic confirms the collapse was intentional.",  
                    meta: "ENTROPY_STABLE // ARCHIVE_01",  
                    image: "https://images.unsplash.com/photo-1614728894747-a83421e2b9c9?w=1200&q=80",  
                    data: [85, 92, 78, 95, 88]  
                },  
                AX02: {  
                    title: "Dark<br>Matter",  
                    label: "Protocol_Initiated: Loom_Sequence",  
                    desc: "Visible light is the shadow cast by deeper architecture. We weave the void to understand the fabric of the vault.",  
                    meta: "SIGNAL_FOCUSED // ARCHIVE_02",  
                    image: "https://images.unsplash.com/photo-1462331940025-496dfbfc7564?w=1200&q=80",  
                    data: [60, 45, 90, 30, 70]  
                },  
                AX03: {  
                    title: "Signal<br>Loss",  
                    label: "Protocol_Initiated: System_Decay",  
                    desc: "Warning: Data integrity failure. The vault is breathing. Entropy is no longer a metric, but a destination.",  
                    meta: "CRITICAL_FAILURE // ARCHIVE_03",  
                    image: "https://images.unsplash.com/photo-1550684848-fac1c5b4e853?w=1200&q=80",  
                    data: [10, 20, 15, 5, 30]  
                }  
            }  
        };  
  
        let stabilityChart;  
  
  
        function updateClock() {  
            const now = new Date();  
            const year = now.getFullYear();  
            const month = String(now.getMonth() + 1).padStart(2, '0');  
            const day = String(now.getDate()).padStart(2, '0');  
            const h = String(now.getHours()).padStart(2, '0');  
            const m = String(now.getMinutes()).padStart(2, '0');  
            const s = String(now.getSeconds()).padStart(2, '0');  
            document.getElementById('timestamp').innerText = `${year}.${month}.${day} // ${h}:${m}:${s}`;  
        }  
  
        function logToTerminal(msg, color = 'white/40') {  
            const display = document.getElementById('terminal-display');  
            const p = document.createElement('p');  
            p.className = `text-${color}`;  
            p.innerText = `>> ${msg.toUpperCase()}`;  
            display.appendChild(p);  
            display.scrollTop = display.scrollHeight;  
        }  
  
        function handleTerminalEntry(e) {  
            if (e.key === 'Enter') {  
                const input = e.target.value.trim();  
                if (input) {  
                    logToTerminal(input, 'white');  
                    e.target.value = '';  
                    setTimeout(() => processQuery(input), 500);  
                }  
            }  
        }  
  
        function processQuery(query) {  
            const q = query.toLowerCase();  
            if (q.includes('status')) {  
                logToTerminal('System Integrity: 98.4% - Nodes Operational.', 'cyan-400');  
            } else if (q.includes('node')) {  
                logToTerminal(`Current Node: ${state.currentArchive} - Location: Nova Scotia.`, 'cyan-400');  
            } else {  
                logToTerminal('Unknown command sequence. Query rejected.', 'red-400');  
            }  
        }  
  
        function initCharts() {  
            const ctx = document.getElementById('stabilityChart').getContext('2d');  
            stabilityChart = new Chart(ctx, {  
                type: 'radar',  
                data: {  
                    labels: ['SIGNAL', 'FLUX', 'LATENCY', 'COHERENCE', 'ENTROPY'],  
                    datasets: [{  
                        data: state.archives.AX01.data,  
                        backgroundColor: 'rgba(34, 211, 238, 0.1)',  
                        borderColor: 'rgba(34, 211, 238, 0.4)',  
                        borderWidth: 1,  
                        pointRadius: 0  
                    }]  
                },  
                options: {  
                    responsive: true,  
                    maintainAspectRatio: false,  
                    scales: {  
                        r: {  
                            angleLines: { color: 'rgba(255,255,255,0.05)' },  
                            grid: { color: 'rgba(255,255,255,0.05)' },  
                            pointLabels: { color: 'rgba(255,255,255,0.2)', font: { size: 8 } },  
                            ticks: { display: false },  
                            suggestedMin: 0,  
                            suggestedMax: 100  
                        }  
                    },  
                    plugins: { legend: { display: false } }  
                }  
            });  
        }  
  
        function switchArchive(id) {  
            const data = state.archives[id];  
            state.currentArchive = id;  
              
            const wrapper = document.getElementById('glitch-wrapper');  
            const content = document.getElementById('content-block');  
              
            wrapper.classList.add('glitch-active');  
            content.style.opacity = '0';  
  
            setTimeout(() => {  
                document.getElementById('archive-title').innerHTML = data.title;  
                document.getElementById('archive-label').innerText = data.label;  
                document.getElementById('archive-description').innerText = data.desc;  
                document.getElementById('archive-metadata').innerText = data.meta;  
                document.getElementById('main-visual').src = data.image;  
                  
                stabilityChart.data.datasets[0].data = data.data;  
                const accent = id === 'AX03' ? 'rgba(239, 68, 68, 0.4)' : 'rgba(34, 211, 238, 0.4)';  
                const bgAccent = id === 'AX03' ? 'rgba(239, 68, 68, 0.1)' : 'rgba(34, 211, 238, 0.1)';  
                stabilityChart.data.datasets[0].borderColor = accent;  
                stabilityChart.data.datasets[0].backgroundColor = bgAccent;  
                stabilityChart.update();  
  
                wrapper.classList.remove('glitch-active');  
                content.style.opacity = '1';  
                  
                if (id === 'AX03') {  
                    document.getElementById('signal-status').innerText = 'Status: Entropy_Critical';  
                    document.getElementById('signal-status').className = 'text-red-500 tracking-widest';  
                } else {  
                    document.getElementById('signal-status').innerText = 'Status: Entropy_Stable';  
                    document.getElementById('signal-status').className = 'tracking-widest';  
                }  
            }, 800);  
        }  
  
        function aiSynthesizeVisual() {  
            const loader = document.getElementById('synth-loader');  
            loader.classList.remove('hidden');  
            logToTerminal('Initiating neural visual synthesis...', 'cyan-400');  
              
            setTimeout(() => {  
                loader.classList.add('hidden');  
                logToTerminal('Synthesis complete. New visual architecture mapped.', 'cyan-400');  
            }, 3000);  
        }  
  
        function aiDecipherDescription() {  
            const desc = document.getElementById('archive-description');  
            desc.style.opacity = '0.2';  
            logToTerminal('Deciphering encrypted lore fragments...', 'cyan-400');  
              
            setTimeout(() => {  
                desc.style.opacity = '1';  
                logToTerminal('Decryption layer applied successfully.', 'cyan-400');  
            }, 2000);  
        }  
  
        function aiVocalize() {  
            logToTerminal('Synthesizing vocal output for current node...', 'white');  
            // Mock vocalization feedback  
            const btn = event.currentTarget;  
            btn.innerText = '◈ VOCALIZING...';  
            setTimeout(() => { btn.innerText = '▣ VOCALIZE_NODE'; }, 3000);  
        }  
  
        function toggleAudio() {  
            state.isMuted = !state.isMuted;  
            const status = document.getElementById('audio-status');  
            const icon = document.getElementById('audio-icon');  
              
            if (state.isMuted) {  
                status.innerText = 'System_Dormant';  
                status.className = 'text-[8px] font-bold uppercase tracking-widest text-white/20';  
                icon.innerText = '⧒';  
            } else {  
                status.innerText = 'Transmitting_Drone';  
                status.className = 'text-[8px] font-bold uppercase tracking-widest text-cyan-400 animate-pulse';  
                icon.innerText = '⧔';  
                logToTerminal('Acoustic environment initialized.', 'cyan-400');  
            }  
        }  
  
        window.onload = () => {  
            updateClock();  
            initCharts();  
            setInterval(updateClock, 1000);  
              
            // Auto-awake visual on delay  
            setTimeout(() => {  
                document.getElementById('main-visual').classList.add('active');  
            }, 1000);  
  
            logToTerminal('Vault system online. Authorization recognized.');  
        };  
    </script>  
</body>  
</html>  
  


